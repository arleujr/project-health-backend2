# Runtime
NODE_ENV=development
PORT=3333
APP_NAME=Projeto Health
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Supabase/PostgreSQL
# Runtime: Supabase Session Pooler (port 5432) is recommended for persistent servers such as Render.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Migrations: direct database URL.
DIRECT_URL=postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Email OTP (Resend)
RESEND_API_KEY=
EMAIL_FROM=Projeto Health <login@your-domain.com>

# AI / Groq OpenAI-compatible API
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
